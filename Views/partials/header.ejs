<header class="header">
  <nav class="navbar">
    <a href="/" class="nav-logo">Encanto Rústico</a>

    <ul class="nav-menu">
      <li><a href="/" class="nav-link">Home</a>
      </li>
      <li><a href="/products" class="nav-link"
          hx-get="/products" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">Produtos</a>
      </li>
      <li><a href="/about" class="nav-link"
          hx-get="/about" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">Sobre</a>
      </li>
      <li><a href="/contact" class="nav-link"
          hx-get="/contact" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">Contato</a>
      </li>
      <!-- Icons are now inside the nav-menu -->
      <li class="header-icons-container">
        <div class="header-icons">
          <% if (user) { %>
            <a href="/profile" class="nav-link" aria-label="Perfil do Usuário"
              hx-get="/profile" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">
              <span class="material-icons notranslate md-22">person</span>
            </a>

            <% if (user.role==='admin' ) { %>
              <a href="/admin/dashboard" class="nav-link" aria-label="Painel do Administrador"
              hx-get="/admin/dashboard" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">
                <span class="material-icons notranslate md-22">admin_panel_settings</span>
              </a>
              <% } %>

                <% if (user.role==='delivery' || user.role==='admin' ) { %>
                  <a href="/admin/delivery" class="nav-link" aria-label="Painel do Entregador" 
                  hx-get="/admin/delivery" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">
                    <span class="material-icons notranslate md-22">local_shipping</span>
                  </a>
                <% } %>

                    <% if (user.role==='staff' || user.role==='admin' ) { %>
                      <a href="/admin/inventory" class="nav-link" aria-label="Estoque" 
                            hx-get="/admin/inventory" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">
                        <span class="material-icons notranslate md-22">inventory</span>
                      </a>
                      <% } %>

                        <a href="/logout" class="nav-link" aria-label="Sair" 
                            hx-get="/logout" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">
                          <span class="material-icons notranslate md-22">logout</span>
                        </a>
                        <% } else { %>
                          <a href="/login" class="nav-link" aria-label="Login"
                            hx-get="/login" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">
                            <span class="material-icons notranslate md-22">person</span>
                          </a>
                          <% } %>
                            <a href="/favorites" class="nav-link" aria-label="Meus Favoritos"
                              hx-get="/favorites" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">
                              <span class="material-icons notranslate md-22">favorite_border</span>
                            </a>
                            <a href="/cart" class="nav-link" aria-label="Meu Carrinho"
                              hx-get="/cart" hx-target="#main-content" hx-push-url="true" hx-swap="innerHTML">
                              <span class="material-icons notranslate md-22">shopping_cart</span>
                            </a>
        </div>
      </li>
    </ul>

    <div class="hamburger">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </div>
  </nav>
  <div class="nav-overlay"></div>
</header>