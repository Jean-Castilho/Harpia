<% const items=Array.isArray(products) ? products : (Array.isArray(allProducts) ? allProducts : []); const
  userId=session?.user?._id || null; const favorites=(session?.user?.favorites || []).map(String); const
  cart=(session?.user?.cart || []).map(String); %>

  <style>
    /* ===== General Section Styles ===== */
    .in-cart i {
      color: #28a745;
      /* Verde para indicar que está no carrinho */
    }

    .icon-btn {
      cursor: pointer;
    }

    .product-categories {
      margin: 0px 0;
    }

    /* ===== Product Card Specific Styles ===== */
    .category-card-content {
      padding: 3px;
    }
  </style>

  <section class="hero-section">
    <div class="hero-content">
      <h1>Móveis Rústicos que </br> Contam Histórias</h1>
      <a href="/register" class="btn btn-primario" style="color: #ffffff;">Registre-se</a>

    </div>
  </section>

  <div class="container">
    <h2 class="section-title">Destaques da Semana</h2>
    <section class="featured-products">
      <div class="product-grid">
        <% if (items.length> 0) { %>
          <% items.slice(0, 1).forEach(product=> { %>
            <%- include('../../partials/_product-card', { product, favorites, cart, cardType: 'main' }) %>
              <% }); %>
                <% } else { %>
                  <p>Nenhum produto em destaque no momento. Volte em breve!</p>
                  <% } %>
      </div>
    </section>

    <section class="product-categories">
      <h2 class="section-title">Categorias em Destaque</h2>
      <div class="category-grid">
        <% const categories=['Sala de Estar', 'Área Gourmet' , 'Cozinha' , 'Escritorio' ]; %>
          <% categories.forEach(category=> { %>
            <div class="category-card">
              <a href="/category/<%= category %>" class="category-title-link">
                <h3>
                  <%= category %>
                </h3>
              </a>
              <div class="category-products-scroll">
                <% const productsInCategory=items.filter(p=> p.categoria === category); %>
                  <% if (productsInCategory && productsInCategory.length> 0) { %>
                    <% productsInCategory.forEach(product=> { %>


                      <%- include('../../partials/_product-card', { product, favorites, cart, cardType: 'category' }) %>

                        <% }); %>
                          <% } else { %>
                            <p>Nenhum produto disponível nesta categoria no momento.</p>
                            <% } %>
              </div>
            </div>
            <% }); %>
      </div>
    </section>
  </div>

    <div id="notification-home"
      style="display: none; position: fixed; top: 20px; right: 20px; z-index: 1050; padding: 15px; border-radius: 5px; color: white;">
    </div>


    <script type="module">
        // Importa as funções utilitárias (DEVE SER NO TOPO DO MÓDULO)
        import { getLocalStorageFavorites, addLocalStorageFavorite, removeLocalStorageFavorite, showNotification } from '/js/utils.js';
        
      document.addEventListener('DOMContentLoaded', () => {
        const isAuthenticated = <%= isAuthenticated %>; // Declarada uma única vez aqui

        const csrfToken = '<%= csrfToken %>'; // Pega o token CSRF renderizado pelo EJS

        // Função auxiliar para showNotification com ID específico
        const showHomeNotification = (message, isSuccess) => showNotification(message, isSuccess, 'notification-home');

        const favoriteButtons = document.querySelectorAll('.favorite-btn'); // Declaração adicionada aqui
        favoriteButtons.forEach(button => {
          button.addEventListener('click', async (event) => {
            const productId = button.dataset.productId;
            if (!productId) return;

            if (!isAuthenticated) {
                event.preventDefault(); // Impede o redirecionamento para /login
                const isCurrentlyFavorited = button.classList.contains('favorited');
                if (isCurrentlyFavorited) {
                    removeLocalStorageFavorite(productId); // Usa a função importada
                    showHomeNotification('Produto removido dos favoritos (local).', true); // Usa a função importada
                } else {
                    addLocalStorageFavorite(productId); // Usa a função importada
                    showHomeNotification('Produto adicionado aos favoritos (local).', true); // Usa a função importada
                }
                button.classList.toggle('favorited');
                const icon = button.querySelector('i');
                icon.textContent = isCurrentlyFavorited ? 'favorite_border' : 'favorite';
            } else {
              // Lógica existente para usuários logados (requisição AJAX)
              event.preventDefault();
              const isFavorited = button.classList.contains('favorited');
              const url = isFavorited ? '/auth/favorites/remove' : '/auth/favorites/add';

              try {
                const response = await fetch(url, {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                    'x-csrf-token': csrfToken // Envia o token no cabeçalho
                  },
                  body: JSON.stringify({
                    productId: productId,
                    _csrf: csrfToken // Envia o token no corpo também por segurança
                  })
                });
                const result = await response.json();
                showHomeNotification(result.message, response.ok); // Usa a função importada
                if (result.success) {
                  button.classList.toggle('favorited');
                  const icon = button.querySelector('i');
                  icon.textContent = isFavorited ? 'favorite_border' : 'favorite';
                }
              } catch (error) {
                showHomeNotification('Erro de conexão. Tente novamente.', false); // Usa a função auxiliar
              } // Mantém a notificação original para erros de conexão
            }
          });
        });

        // Handle cart clicks
        const cartButtons = document.querySelectorAll('.add-to-cart-btn');
        cartButtons.forEach(button => {
          button.addEventListener('click', async (event) => {
            event.preventDefault();

            if (button.classList.contains('in-cart')) {
              window.location.href = '/cart';
              return;
            }

            const productId = button.dataset.productId;
            if (!productId) return;

            const url = `/auth/cart/add`;

            try {
              const response = await fetch(url, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                  productId: productId,
                  _csrf: csrfToken // Envia o token no corpo também por segurança
                })
              });

              const result = await response.json();
              showHomeNotification(result.message, result.success); // Usa a função importada

              if (result.success) {
                button.classList.add('in-cart');
                const icon = button.querySelector('i');
                icon.textContent = 'shopping_cart_checkout';
              }

            } catch (error) {
              showHomeNotification('Erro de conexão. Tente novamente.', false); // Usa a função importada
            }
          });
        });

        // Inicializa o estado dos botões de favoritos ao carregar a página para usuários não logados
        if (!isAuthenticated) {
            const localFavorites = getLocalStorageFavorites();
            favoriteButtons.forEach(button => {
                if (localFavorites.includes(button.dataset.productId)) {
                    button.classList.add('favorited');
                    button.querySelector('i').textContent = 'favorite';
                }
            });
        }
      });
    </script>