<div class="container" style="text-align: center; margin-top: 2rem; margin-bottom: 2rem;">
    <div class="card" style="max-width: 450px; margin: auto; padding: 1.5rem;">

        <% if (qr_code && qr_code_base64) { %>

            <div class="pix-info" style="margin-top: 0.25rem;">

                <h3>Pague com Pix</h3>
                <strong style=="font-size: 0.35rem">Aponte a câmera do seu celular para o QR Code ou use o código abaixo
                    para finalizar a compra.</strong>

                <img src="data:image/png;base64, <%= qr_code_base64 %>" alt="QR Code Pix"
                    style="color: var(--cor-destaque); max-width: 65%; height: auto; margin-top: 0.25rem; margin-bottom: 0rem;">

                <div style="background-color: #f0f0f0; padding: 0.6rem; border-radius: var(--borda-radius); margin-top: 0.5rem; word-wrap: break-word;">
                  
                    <p id="pix-code" style="margin: 0; font-size: 14px;">
                        <%= qr_code %>
                    </p>
              
                </div>
                <button class="btn btn-secundario" onclick="copyPixCode()"
                    style="margin-top: 1rem; padding: 0.5rem">Copiar
                    Código</button>

                <div id="payment-status" style="margin-top: 1.5rem; text-align: left; background: #fafafa; padding: 1rem; border-radius: 10px;">
                  <p style="margin: 0 0 0.5rem; font-weight: 600;">Status do pagamento:</p>
                  <p id="payment-status-text" style="margin: 0 0 0.75rem; font-size: 1rem; color: #333;"><%= paymentStatusLabel || 'Aguardando confirmação...' %></p>
                  <p id="payment-status-message" style="margin: 0; font-size: 0.95rem; color: #666;">Aguardando o Pix ser compensado automaticamente.</p>
                </div>
            </div>
            <% } %>

                <div style="margin-top: 2rem;">
                    <a href="/profile" class="btn btn-destaque">Ver Meus Pedidos</a>
                </div>
    </div>
</div>

<script>
    const orderId = "<%= orderId %>";
    const paymentStatusText = document.getElementById('payment-status-text');
    const paymentStatusMessage = document.getElementById('payment-status-message');
    const paymentStatusDiv = document.getElementById('payment-status');
    let paymentStatusInterval;

    async function refreshPaymentStatus() {
        try {
            const response = await fetch(`/payment/${orderId}/status`, {
                headers: { 'Accept': 'application/json' }
            });

            if (!response.ok) {
                console.warn('Falha ao consultar o status do pagamento', response.status);
                return;
            }

            const data = await response.json();
            const status = data.status || 'pending';
            const label = status === 'paid' ? '✅ Pago' : status.replace('_', ' ').toUpperCase();

            // Atualiza o texto com transição suave
            paymentStatusText.style.transition = 'color 0.3s ease';
            
            if (status === 'paid') {
                // Alternar cor para indicar sucesso
                paymentStatusDiv.style.backgroundColor = '#e8f5e9';
                paymentStatusDiv.style.borderLeft = '4px solid #4caf50';
                paymentStatusText.style.color = '#2e7d32';
                paymentStatusText.textContent = label;
                paymentStatusMessage.textContent = 'Pagamento confirmado! Redirecionando...';
                paymentStatusMessage.style.color = '#2e7d32';
                
                clearInterval(paymentStatusInterval);
                
                // Reproduz um som de sucesso (opcional)
                playSuccessSound();
                
                // Redireciona para pedidos após 3 segundos
                setTimeout(() => {
                    window.location.href = '/orders';
                }, 3000);
            } else {
                // Status pendente
                paymentStatusDiv.style.backgroundColor = '#fff3e0';
                paymentStatusDiv.style.borderLeft = '4px solid #ff9800';
                paymentStatusText.style.color = '#e65100';
                paymentStatusText.textContent = label;
                paymentStatusMessage.textContent = 'Aguardando a compensação do Pix. Esta página atualizará automaticamente.';
                paymentStatusMessage.style.color = '#e65100';
            }
        } catch (error) {
            console.error('Erro ao atualizar status do pagamento:', error);
            paymentStatusMessage.textContent = 'Erro ao atualizar o status. Tentando novamente...';
        }
    }

    function playSuccessSound() {
        // Cria um som simples de sucesso usando Web Audio API
        try {
            const audioContext = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            
            oscillator.frequency.value = 800;
            oscillator.type = 'sine';
            
            gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);
            
            oscillator.start(audioContext.currentTime);
            oscillator.stop(audioContext.currentTime + 0.5);
        } catch (e) {
            console.log('Áudio não disponível');
        }
    }

    // Inicia o polling a cada 5 segundos
    paymentStatusInterval = setInterval(refreshPaymentStatus, 5000);
    refreshPaymentStatus();

    function copyPixCode() {
        const pixCodeElement = document.getElementById('pix-code');
        const pixCode = pixCodeElement.textContent;
        const button = event.target;
        
        // Usa a API Clipboard se disponível (mais moderna e confiável)
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(pixCode).then(() => {
                // Feedback visual
                const originalText = button.textContent;
                button.textContent = '✅ Copiado!';
                button.style.backgroundColor = '#4caf50';
                
                setTimeout(() => {
                    button.textContent = originalText;
                    button.style.backgroundColor = '';
                }, 2000);
                console.log('Código Pix copiado com sucesso');
            }).catch(() => {
                fallbackCopyPix(pixCode, button);
            });
        } else {
            fallbackCopyPix(pixCode, button);
        }
    }

    function fallbackCopyPix(pixCode, button) {
        // Fallback para navegadores antigos
        const textarea = document.createElement('textarea');
        textarea.value = pixCode;
        document.body.appendChild(textarea);
        textarea.select();
        
        try {
            document.execCommand('copy');
            const originalText = button.textContent;
            button.textContent = '✅ Copiado!';
            button.style.backgroundColor = '#4caf50';
            
            setTimeout(() => {
                button.textContent = originalText;
                button.style.backgroundColor = '';
            }, 2000);
        } catch (err) {
            button.textContent = '❌ Erro ao copiar';
            button.style.backgroundColor = '#f44336';
        } finally {
            document.body.removeChild(textarea);
        }
    }
</script>