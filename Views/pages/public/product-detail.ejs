<style>
    /* Estilos específicos para a página de detalhes do produto */
    .product-detail-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 15px;
        display: flex;
        gap: 2rem;
    }

    .product-images {
        flex: 1 1 500px;
        /* Flexível, mas com largura mínima de 500px */
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .main-image-container {
        width: 100%;
        padding-bottom: 75%;
        /* Proporção 4:3 */
        position: relative;
        overflow: hidden;
        border-radius: var(--borda-radius);
        box-shadow: var(--sombra-padrao);
    }

    .main-image-container img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .thumbnail-images {
        display: flex;
        gap: 0.5rem;
        overflow-x: auto;
        padding-bottom: 5px;
        /* Para a barra de rolagem */
    }

    .thumbnail-images img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border: 2px solid transparent;
        border-radius: var(--borda-radius);
        cursor: pointer;
        transition: border-color 0.3s ease;
    }

    .thumbnail-images img.active {
        border-color: var(--cor-destaque);
    }

    .product-info {
        flex: 1 1 400px;
        /* Flexível, mas com largura mínima de 400px */
        padding: 1rem;
        background-color: #fff;
        border-radius: var(--borda-radius);
        box-shadow: var(--sombra-padrao);
    }

    .product-info h1 {
        font-size: 2.5rem;
        color: var(--cor-secundaria);
        margin-top: 0;
        margin-bottom: 1rem;
    }

    .product-info .price {
        font-size: 2rem;
        font-weight: bold;
        color: var(--cor-destaque);
        margin-bottom: 1.5rem;
    }

    .product-info .description {
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--cor-texto-escuro);
        margin-bottom: 1.5rem;
    }

    .product-details-list {
        list-style: none;
        padding: 0;
        margin-bottom: 1.5rem;
    }

    .product-details-list li {
        margin-bottom: 0.5rem;
        color: var(--cor-texto-escuro);
    }

    .product-details-list strong {
        color: var(--cor-secundaria);
    }

    .product-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .btn-primary {
        background-color: var(--cor-destaque);
        color: #fff;
        border: 1px solid var(--cor-destaque);
        padding: 12px 25px;
        border-radius: var(--borda-radius);
        font-weight: bold;
        text-decoration: none;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    .btn-primary:hover {
        background-color: #e06b00;
        /* Um tom mais escuro */
        border-color: #e06b00;
    }

    .btn-outline {
        background-color: transparent;
        color: var(--cor-destaque);
        border: 1px solid var(--cor-destaque);
        padding: 12px 25px;
        border-radius: var(--borda-radius);
        font-weight: bold;
        text-decoration: none;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    .btn-outline:hover {
        background-color: var(--cor-destaque);
        color: #fff;
    }

    .product-card-icons {
        /* Reutilizando estilos do products.ejs */
        position: absolute;
        top: 10px;
        right: 10px;
        display: flex;
        flex-direction: column;
        gap: 5px;
        z-index: 10;
    }

    .icon-btn {
        /* Reutilizando estilos do products.ejs */
        background-color: rgba(255, 255, 255, 0.8);
        border: none;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        color: var(--cor-secundaria);
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    }

    .icon-btn:hover {
        background-color: var(--cor-destaque);
        color: #fff;
        transform: scale(1.1);
    }

    .icon-btn i.material-icons {
        font-size: 20px;
    }

    .favorite-btn.favorited i {
        color: var(--cor-destaque);
    }

    .add-to-cart-btn.in-cart i {
        color: var(--cor-destaque);
    }

    /* Responsividade */
    @media (max-width: 768px) {
        .product-detail-container {
            display: flow;
            flex-direction: column;
            gap: 1.5rem;
        }

        .product-images,
        .product-info {
            flex: 1 1 100%;
        }

        .product-info h1 {
            font-size: 2rem;
        }

        .product-info .price {
            font-size: 1.8rem;
        }

        .product-actions {
            flex-direction: column;
        }

        .btn-primary,
        .btn-outline {
            width: 100%;
            text-align: center;
        }
    }

    /* Responsividade para telas muito pequenas */
    @media (max-width: 480px) {
        .product-info h1 {
            font-size: 1.8rem;
            /* Reduzir ainda mais o título */
        }

        .product-info .price {
            font-size: 1.5rem;
            /* Reduzir ainda mais o preço */
        }

        .product-info .description,
        .product-details-list li {
            font-size: 1rem;
            /* Ajustar tamanho da fonte para melhor leitura */
        }

        .btn-primary,
        .btn-outline {
            padding: 10px 20px;
            /* Ajustar padding dos botões */
            font-size: 0.9rem;
            /* Ajustar tamanho da fonte dos botões */
        }

        .thumbnail-images img {
            width: 60px;
            /* Reduzir miniaturas em telas muito pequenas */
            height: 60px;
        }
    }
</style>

<div class="product-detail-container">
    <div class="product-images">
        <div class="main-image-container">
            <% if (product.imagens && product.imagens.length> 0) { %>
                <img id="main-product-image" src="/products/images/<%= product.imagens[0] %>" alt="<%= product.nome %>">
                <% } else { %>
                    <img id="main-product-image" src="/assets/img/fallback.jpg" alt="Imagem não disponível">
                    <% } %>
                        <div class="product-card-icons">
                            <% const id=product._id || '' ; const isFavorited=(session?.user?.favorites ||
                                []).map(String).includes(String(id)); const isInCart=(session?.user?.cart ||
                                []).map(String).includes(String(id)); const favoritUrl=session?.user?._id ?
                                `/auth/favorites/add` : '/login' ; %>
                                <a href="<%= favoritUrl %>"
                                    class="favorite-btn icon-btn <%= isFavorited ? 'favorited' : '' %>"
                                    data-product-id="<%= id %>">
                                    <i class="material-icons">
                                        <%= isFavorited ? 'favorite' : 'favorite_border' %>
                                    </i>
                                </a>
                        </div>
        </div>
        <% if (product.imagens && product.imagens.length> 1) { %>
            <div class="thumbnail-images">
                <% product.imagens.forEach((image, index)=> { %>
                    <img src="/products/images/<%= image %>" alt="<%= product.nome %> thumbnail <%= index + 1 %>"
                        data-full-image="/products/images/<%= image %>" class="<%= index === 0 ? 'active' : '' %>">
                    <% }); %>
            </div>
            <% } %>
    </div>

    <div class="product-info">
        <h1>
            <%= product.nome %>
        </h1>
        <p class="price">
            <% if (product.preco !=null) { %>
                <%= Number(product.preco).toLocaleString('pt-BR', { style: 'currency' , currency: 'BRL' }) %>
                    <% } else { %>
                        Preço sob consulta
                        <% } %>
        </p>
        <p class="description">
            <%= product.descricao %>
        </p>

        <ul class="product-details-list">
            <% if (product.categoria) { %>
                <li><strong>Categoria:</strong>
                    <%= Array.isArray(product.categoria) ? product.categoria.join(', ') : product.categoria %></li>
            <% } %>
            <% if (product.estilo) { %>
                <li><strong>Estilo:</strong> <%= product.estilo %></li>
            <% } %>
            <% if (product.colecao) { %>
                <li><strong>Coleção:</strong> <%= product.colecao %></li>
            <% } %>
            <% if (product.dimensoes && product.dimensoes.altura && product.dimensoes.largura && product.dimensoes.profundidade) { %>
                <li><strong>Dimensões:</strong> A <%= product.dimensoes.altura %>cm x L <%= product.dimensoes.largura %>cm x P <%= product.dimensoes.profundidade %>cm</li>
            <% } %>
            <% if (product.peso) { %>
                <li><strong>Peso:</strong> <%= product.peso %> kg</li>
            <% } %>
            <% if (product.estoque != null) { %>
                <li><strong>Disponibilidade:</strong> <%= product.estoque > 0 ? ' Em estoque' : 'Esgotado' %>
                </li>
                <% } %>
                    <% if (product.garantia) { %>
                        <li><strong>Garantia:</strong>
                            <%= product.garantia %> meses
                        </li>
                        <% } %>
        </ul>

        <div class="product-actions">
            <a href="<%= session?.user?._id ? (isInCart ? '/cart' : `/auth/cart/add`) : '/login' %>"
                class="btn-primary add-to-cart-btn" data-product-id="<%= id %>">
                <%= isInCart ? 'Ver no Carrinho' : 'Adicionar ao Carrinho' %>
            </a>
            <a href="/products" class="btn-outline">Continuar Comprando</a>
        </div>
    </div>
</div>

<div id="notification-products"
    style="display: none; position: fixed; top: 20px; right: 20px; z-index: 1050; padding: 15px; border-radius: 5px; color: white;">
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const mainProductImage = document.getElementById('main-product-image');
        const thumbnailImages = document.querySelectorAll('.thumbnail-images img');
        const notification = document.getElementById('notification-products');

        // --- Lógica de troca de imagem principal ---
        thumbnailImages.forEach(thumbnail => {
            thumbnail.addEventListener('click', () => {
                // Remove a classe 'active' de todas as miniaturas
                thumbnailImages.forEach(img => img.classList.remove('active'));
                // Adiciona a classe 'active' à miniatura clicada
                thumbnail.classList.add('active');
                // Altera a imagem principal
                mainProductImage.src = thumbnail.dataset.fullImage;
            });
        });

        // --- Lógica de Notificação (Favoritos e Carrinho) ---
        function showNotification(message, isSuccess) {
            notification.textContent = message;
            notification.style.backgroundColor = isSuccess ? '#28a745' : '#dc3545';
            notification.style.display = 'block';
            setTimeout(() => {
                notification.style.display = 'none';
            }, 3000);
        }

        const csrfToken = '<%= csrfToken %>'; // Certifique-se de que o csrfToken está disponível

        // Lógica para Favoritos
        const favoriteButton = document.querySelector('.favorite-btn');
        if (favoriteButton) {
            favoriteButton.addEventListener('click', async (event) => {
                event.preventDefault();
                const productId = favoriteButton.dataset.productId;
                if (!productId) return;

                const isFavorited = favoriteButton.classList.contains('favorited');
                const url = isFavorited ? '/auth/favorites/remove' : '/auth/favorites/add';

                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'x-csrf-token': csrfToken
                        },
                        body: JSON.stringify({
                            productId: productId,
                            _csrf: csrfToken
                        })
                    });

                    const result = await response.json();
                    showNotification(result.message, result.success);

                    if (result.success) {
                        favoriteButton.classList.toggle('favorited');
                        const icon = favoriteButton.querySelector('i');
                        icon.textContent = isFavorited ? 'favorite_border' : 'favorite';
                    }
                } catch (error) {
                    showNotification('Erro de conexão. Tente novamente.', false);
                }
            });
        }

        // Lógica para Carrinho
        const addToCartButton = document.querySelector('.add-to-cart-btn');
        if (addToCartButton) {
            addToCartButton.addEventListener('click', async (event) => {
                event.preventDefault();
                // Se o botão já indica que está no carrinho, redireciona para o carrinho
                if (addToCartButton.textContent === 'Ver no Carrinho') {
                    window.location.href = '/cart';
                    return;
                }

                const productId = addToCartButton.dataset.productId;
                if (!productId) return;

                const url = `/auth/cart/add`;

                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'x-csrf-token': csrfToken
                        },
                        body: JSON.stringify({
                            productId: productId,
                            _csrf: csrfToken
                        })
                    });

                    const result = await response.json();
                    showNotification(result.message, result.success);

                    if (result.success) {
                        // Atualiza o texto do botão para "Ver no Carrinho"
                        addToCartButton.textContent = 'Ver no Carrinho';
                        // Adiciona a classe 'in-cart' para estilização se necessário
                        addToCartButton.classList.add('in-cart');
                    }
                } catch (error) {
                    showNotification('Erro de conexão. Tente novamente.', false);
                }
            });
        }
    });
</script>