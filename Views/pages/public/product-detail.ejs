<style>
    /* Estilos específicos para a página de detalhes do produto */
    .product-detail-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 15px;
        display: flex;
        gap: 2rem;
    }

    .product-images {
        flex: 1 1 500px;
        /* Flexível, mas com largura mínima de 500px */
        display: flex;
        padding: 1rem;
        flex-direction: column;
        gap: 1rem;
    }

    .main-image-container {
        width: 100%;
        padding-bottom: 75%;
        /* Proporção 4:3 */
        position: relative;
        overflow: hidden;
        border-radius: var(--borda-radius);
        box-shadow: var(--sombra-padrao);
    }

    .main-image-container img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .thumbnail-images {
        display: flex;
        padding: 1rem;
        gap: 0.5rem;
        overflow-x: auto;
        padding-bottom: 5px;
        /* Para a barra de rolagem */
    }

    .thumbnail-images img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border: 2px solid transparent;
        border-radius: var(--borda-radius);
        cursor: pointer;
        transition: border-color 0.3s ease;
    }

    .thumbnail-images img.active {
        border-color: var(--cor-destaque);
    }

    .product-info {
        flex: 1 1 400px;
        /* Flexível, mas com largura mínima de 400px */
        margin: 0.6rem;
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background-color: #fff;
        border-radius: var(--borda-radius);
        box-shadow: var(--sombra-padrao);
    }

    .product-info h1 {
        font-size: 2.5rem;
        color: var(--cor-secundaria);
        margin-top: 0;
        margin-bottom: 1rem;
    }

    .product-info .price {
        font-size: 2rem;
        font-weight: bold;
        color: var(--cor-destaque);
        margin-bottom: 1.5rem;
    }

    .product-info .description {
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--cor-texto-escuro);
        margin-bottom: 1.5rem;
    }

    .product-details-list {
        list-style: none;
        padding: 0;
        margin-bottom: 1.5rem;
    }

    .product-details-list li {
        margin-bottom: 0.5rem;
        color: var(--cor-texto-escuro);
    }

    .product-details-list strong {
        color: var(--cor-secundaria);
    }

    .product-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .btn-primary {
        background-color: var(--cor-destaque);
        color: #fff;
        border: 1px solid var(--cor-destaque);
        padding: 12px 25px;
        border-radius: var(--borda-radius);
        font-weight: bold;
        text-decoration: none;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    .btn-primary:hover {
        background-color: #e06b00;
        /* Um tom mais escuro */
        border-color: #e06b00;
    }

    .btn-outline {
        background-color: transparent;
        color: var(--cor-destaque);
        border: 1px solid var(--cor-destaque);
        padding: 12px 25px;
        border-radius: var(--borda-radius);
        font-weight: bold;
        text-decoration: none;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    .btn-outline:hover {
        background-color: var(--cor-destaque);
        color: #fff;
    }

    .product-card-icons {
        /* Reutilizando estilos do products.ejs */
        position: absolute;
        top: 10px;
        right: 10px;
        display: flex;
        flex-direction: column;
        gap: 5px;
        z-index: 10;
    }

    .icon-btn {
        background-color: rgba(255, 255, 255, 0.8);
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.3s ease, opacity 0.2s ease;
        color: var(--cor-secundaria);
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        padding: 0;
        font-size: inherit;
    }

    .icon-btn:hover {
        color: var(--cor-destaque);
        transform: scale(1.15);
    }

    .icon-btn:active {
        transform: scale(0.95);
    }

    .icon-btn i.material-icons {
        font-size: 20px;
    }

    .favorite-btn.favorited i {
        color: var(--cor-destaque);
    }

    .add-to-cart-btn.in-cart i {
        color: var(--cor-destaque);
    }

    /* Estado de carregamento */
    .icon-btn[style*="opacity: 0.6"] {
        opacity: 0.6 !important;
        pointer-events: none;
        animation: pulse 1s infinite;
    }

    @keyframes pulse {
        0%, 100% {
            opacity: 0.6;
        }
        50% {
            opacity: 0.4;
        }
    }

    /* Responsividade */
    @media (max-width: 740px) {
        .product-detail-container {
            display: flow;
            flex-direction: column;
            gap: 1.5rem;
        }

        .product-images,
        .product-info {
            flex: 1 1 100%;
        }

        .product-info h1 {
            font-size: 2rem;
        }

        .product-info .price {
            font-size: 1.8rem;
        }

        .product-actions {
            flex-direction: column;
        }

        .btn-primary,
        .btn-outline {
            width: 100%;
            text-align: center;
        }
    }

    /* Responsividade para telas muito pequenas */
    @media (max-width: 480px) {
        .product-info h1 {
            font-size: 1.8rem;
            /* Reduzir ainda mais o título */
        }

        .product-info .price {
            font-size: 1.5rem;
            /* Reduzir ainda mais o preço */
        }

        .product-info .description,
        .product-details-list li {
            font-size: 1rem;
            /* Ajustar tamanho da fonte para melhor leitura */
        }

        .btn-primary,
        .btn-outline {
            padding: 10px 20px;
            /* Ajustar padding dos botões */
            font-size: 0.9rem;
            /* Ajustar tamanho da fonte dos botões */
        }

        .thumbnail-images img {
            width: 60px;
            /* Reduzir miniaturas em telas muito pequenas */
            height: 60px;
        }
    }

    /* Grid para telas grandes (>=1000px): 2 colunas x 2 linhas */
    @media (min-width: 750px) {
        .product-detail-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto auto 1fr;
            /* 3 rows: first two for images/info, last for related/comments */
            gap: 2rem;
            grid-template-areas:
                "images info"
                "images info"
                "listproduct comments";

            align-items: start;
        }

        .product-images {
            grid-area: images;
        }

        .product-info {
            padding: 3.5rem;
            grid-area: info;
        }

        .product-coments {
            grid-area: comments;
        }

        .list-product {
            grid-area: listproduct;
        }

        /* Estilos para produtos relacionados (movidos do JS) */
        .related-grid {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .related-card {
            display: flex;
            gap: 0.6rem;
            text-decoration: none;
            color: inherit;
            align-items: center;
            padding: 0.5rem;
            border-radius: 8px;
            transition: background .15s;
        }

        .related-card:hover {
            background: rgba(0, 0, 0, 0.03);
        }

        .related-thumb img {
            width: 64px;
            height: 64px;
            object-fit: cover;
            border-radius: 6px;
        }

        .related-info {
            display: flex;
            flex-direction: column;
        }

        .related-name {
            font-weight: 600;
            font-size: 0.95rem;
        }

        .related-price {
            color: var(--cor-texto-escuro);
            font-size: 0.9rem;
        }

        @media (min-width:1024px) {
            .related-grid {
                flex-direction: column;
            }
        }

        /* Ajuste para o tamanho da lista de comentários no desktop */
        .comment-list {
            max-height: 360px;
        }

        .list-product {
            min-height: 160px;
        }

        .product-images,
        .product-info {
            align-self: start;
        }

        .product-coments,
        .list-product {
            background: #fff;
            border-radius: var(--borda-radius);
            box-shadow: var(--sombra-padrao);
            padding: 1rem;
        }
    }
</style>

<div class="product-detail-container">

    <div class="product-images">
        <div class="main-image-container">
            <% if (product.imagens && product.imagens.length> 0) { %>
                <img id="main-product-image" src="/products/images/<%= product.imagens[0] %>" alt="<%= product.nome %>">
                <% } else { %>
                    <img id="main-product-image" src="/assets/img/fallback.jpg" alt="Imagem não disponível">
                    <% } %>
                        <div class="product-card-icons">
                            <% 
                            const id=product._id || '' ; 
                            const isFavorited=(session?.user?.favorites || []).map(String).includes(String(id));
                            const isInCart=(session?.user?.cart || []).map(String).includes(String(id)); 
                            %>
                                <a type="button"
                                    class="favorite-btn icon-btn <%= isFavorited ? 'favorited' : '' %>"
                                    data-product-id="<%= id %>">
                                    <i class="material-icons">
                                        <%= isFavorited ? 'favorite' : 'favorite_border' %>
                                    </i>
                                </a>
                        </div>
        </div>
        <% if (product.imagens && product.imagens.length> 1) { %>
            <div class="thumbnail-images">
                <% product.imagens.forEach((image, index)=> { %>
                    <img src="/products/images/<%= image %>" alt="<%= product.nome %> thumbnail <%= index + 1 %>"
                        data-full-image="/products/images/<%= image %>" class="<%= index === 0 ? 'active' : '' %>">
                    <% }); %>
            </div>
            <% } %>
    </div>

    <div class="product-info">
        <h1>
            <%= product.nome %>
        </h1>
        <p class="price">
            <% if (product.preco !=null) { %>
                <%= Number(product.preco).toLocaleString('pt-BR', { style: 'currency' , currency: 'BRL' }) %>
                    <% } else { %>
                        Preço sob consulta
                        <% } %>
        </p>
        <p class="description">
            <%= product.descricao %>
        </p>

        <ul class="product-details-list">
            <% if (product.categoria) { %>
                <li><strong>Categoria:</strong>
                    <%= Array.isArray(product.categoria) ? product.categoria.join(', ') : product.categoria %></li>
            <% } %>
            <% if (product.estilo) { %>
                <li><strong>Estilo:</strong> <%= product.estilo %></li>
            <% } %>
            <% if (product.colecao) { %>
                <li><strong>Coleção:</strong> <%= product.colecao %></li>
            <% } %>
            <% if (product.dimensoes && product.dimensoes.altura && product.dimensoes.largura && product.dimensoes.profundidade) { %>
                <li><strong>Dimensões:</strong> A <%= product.dimensoes.altura %>cm x L <%= product.dimensoes.largura %>cm x P <%= product.dimensoes.profundidade %>cm</li>
            <% } %>
            <% if (product.peso) { %>
                <li><strong>Peso:</strong> <%= product.peso %> kg</li>
            <% } %>
            <% if (product.estoque != null) { %>
                <li><strong>Disponibilidade:</strong> <%= product.estoque > 0 ? ' Em estoque' : 'Esgotado' %>
                </li>
                <% } %>
                    <% if (product.garantia) { %>
                        <li><strong>Garantia:</strong>
                            <%= product.garantia %> meses
                        </li>
                        <% } %>
        </ul>

        <div class="product-actions">
            <a href="<%= session?.user?._id ? (isInCart ? '/cart' : `/auth/cart/add`) : '/login' %>"
                class="btn-primary add-to-cart-btn" data-product-id="<%= id %>">
                <%= isInCart ? 'Ver no Carrinho' : 'Adicionar ao Carrinho' %>
            </a>
            <a href="<%= session?.user?._id ? (isInCart ? '/login' : `/auth/cart/add`) : '/login' %>"
                class="btn-outline">Continuar Comprando</a>
        </div>
    </div>

    <div class="list-product" id="related-products-section">
        <h3>Produtos Relacionados</h3>
        <div id="related-products-container">
            <!-- Related products will be loaded here by JavaScript -->
            <div style="color:#666; padding: 1rem;">Carregando produtos relacionados...</div>
        </div>
    </div>

    <div class="product-coments">

        <style>
            /* Comentários: UI/UX */
            .comments-section {
                margin-top: 2rem;
                background: #fff;
                border-radius: var(--borda-radius);
                box-shadow: var(--sombra-padrao);
                padding: 1rem;
            }

            .comments-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 0.5rem;
            }

            .comments-count {
                font-weight: 700;
                color: var(--cor-secundaria);
            }

            .comment-list {
                list-style: none;
                padding: 0;
                margin: 0;
                max-height: 320px;
                overflow-y: auto;
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
            }

            .comment {
                display: flex;
                gap: 0.75rem;
                padding: 0.75rem;
                border-radius: 8px;
                background: #fbfbfb;
                align-items: flex-start;
            }

            .comment .avatar {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                background: #e9e9e9;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                color: var(--cor-secundaria);
                flex-shrink: 0;
            }

            .comment .body {
                flex: 1 1 auto;
            }

            .comment .meta {
                font-size: 0.85rem;
                color: #666;
                margin-bottom: 0.25rem;
            }

            .comment .text {
                white-space: pre-wrap;
                color: var(--cor-texto-escuro);
            }

            .comment-form {
                margin-top: 0.75rem;
                display: flex;
                gap: 0.5rem;
                flex-direction: column;
            }

            .comment-form textarea {
                min-height: 80px;
                resize: vertical;
                padding: 0.6rem;
                border-radius: 8px;
                border: 1px solid #e6e6e6;
                font-size: 0.95rem;
            }

            .comment-form .actions {
                display: flex;
                gap: 0.5rem;
                justify-content: flex-end;
            }

            .comment-placeholder {
                padding: 1rem 0;
                color: #777;
            }

            .comment.example {
                background: #fffefa;
                border: 1px dashed #f0e6b6;
            }
        </style>

        <section class="comments-section" aria-labelledby="comments-title">
            <% const productId=product._id || '' ; const comments=product.comentarios || product.comments ||
                product.reviews || []; %>
                <div class="comments-header">
                    <h3 id="comments-title">Comentários</h3>
                    <div class="comments-count">
                        <%= (comments && comments.length) ? comments.length : 0 %> comentários
                    </div>
                </div>

                <% if (comments && comments.length) { %>
                    <ul class="comment-list" id="comment-list">
                        <% comments.forEach(c=> { %>
                            <li class="comment">
                                <div class="avatar">
                                    <%= (c.author && c.author.nome) ? c.author.nome.charAt(0).toUpperCase() : (c.nome ?
                                        c.nome.charAt(0).toUpperCase() : 'U' ) %>
                                </div>
                                <div class="body">
                                    <div class="meta"><strong>
                                            <%= (c.author && c.author.nome) ? c.author.nome : (c.nome || 'Usuário' ) %>
                                        </strong> • <%= new Date(c.criadoEm || c.createdAt ||
                                            Date.now()).toLocaleString('pt-BR') %>
                                    </div>
                                    <div class="text">
                                        <%= c.texto || c.text || c.comentario || '' %>
                                    </div>
                                </div>
                            </li>
                            <% }) %>
                    </ul>
                    <% } else { %>
                        <div class="comment-placeholder">Seja o primeiro a comentar sobre este produto.</div>
                       
                            <% } %>

                                <% if (session?.user?._id) { %>
                                    <form id="comment-form" class="comment-form" aria-label="Formulário de comentário">
                                        <label for="comment-text" class="sr-only">Escreva seu comentário</label>
                                        <textarea id="comment-text" name="text" rows="3"
                                            placeholder="Escreva seu comentário aqui..." required></textarea>
                                        <div class="actions">
                                            <button type="button" id="comment-cancel"
                                                class="btn-outline">Cancelar</button>
                                            <button type="submit" class="btn-primary">Comentar</button>
                                        </div>
                                    </form>
                                    <% } else { %>
                                        <div class="comment-placeholder">Você precisa <a href="/login">entrar</a> para
                                            comentar.</div>
                                        <% } %>
        </section>

    </div>
</div>


<script type="module">
    // Importa o módulo de favoritos reutilizável
    import { initFavoriteButtons, syncLocalFavoritesToServer } from '/js/favorites.js';
    
    console.log("verifica execuçao")
    document.addEventListener('DOMContentLoaded', () => {
        const isAuthenticated = <%= !!session?.user?._id %>

        const mainProductImage = document.getElementById('main-product-image');
        const thumbnailImages = document.querySelectorAll('.thumbnail-images img');
        const commentList = document.getElementById('comment-list');
        const commentPlaceholder = document.querySelector('.comment-placeholder'); // Select the placeholder message
        const sampleCommentsList = document.querySelector('.comment-list .example')?.closest('ul'); // Select the ul containing example comments

        /**
         * Inicializa a galeria de imagens do produto, permitindo a troca de imagem
         * principal ao clicar nas miniaturas.
         */
        function initImageGallery() {
            if (!mainProductImage || thumbnailImages.length === 0) return;

            thumbnailImages.forEach(thumbnail => {
                thumbnail.addEventListener('click', () => {
                    // Remove a classe 'active' de todas as miniaturas
                    thumbnailImages.forEach(img => img.classList.remove('active'));
                    // Adiciona a classe 'active' à miniatura clicada
                    thumbnail.classList.add('active');
                    // Altera a imagem principal
                    mainProductImage.src = thumbnail.dataset.fullImage;
                });
            });
        }

        const csrfToken =  <%- JSON.stringify(csrfToken || '') %>

        // Função auxiliar para exibir notificação usando o sistema global
        const showProductNotification = (message, isSuccess) => window.NotificationSystem?.show(message, isSuccess ? 'success' : 'error');

        // DEBUG: Log para verificar se os dados estão corretos
        console.log('Product Detail - isAuthenticated:', isAuthenticated, 'csrfToken:', !!csrfToken);

        // Inicializa o botão de favorito usando o módulo reutilizável
        try {
            initFavoriteButtons({ isAuthenticated, csrfToken });
            console.log('Favorito botão inicializado com sucesso.');
        } catch (error) {
            console.error('Erro ao inicializar botão de favorito:', error);
        }

        // Inicializa a galeria de imagens
        initImageGallery();

        // Lógica para Carrinho
        const addToCartButton = document.querySelector('.add-to-cart-btn');
        if (addToCartButton) {
            addToCartButton.addEventListener('click', async (event) => {
                event.preventDefault();
                // Se o botão já indica que está no carrinho, redireciona para o carrinho
                if (addToCartButton.textContent === 'Ver no Carrinho') {
                    window.location.href = '/cart';
                    return;
                }

                const productId = addToCartButton.dataset.productId;
                if (!productId) return;

                const url = `/auth/cart/add`;

                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'x-csrf-token': csrfToken
                        },
                        body: JSON.stringify({ productId })
                    });

                    const result = await response.json();
                    showProductNotification(result.message, result.success);

                    console.log('Resposta do servidor para adicionar ao carrinho:', result); // Log para depuração
                    if (result.success) {
                        addToCartButton.textContent = 'Ver no Carrinho';
                        addToCartButton.classList.add('in-cart');
                    }
                } catch (error) {
                    showProductNotification('faça login e tente novamente.', false);
                }
            });
        }

        // Sincroniza favoritos locais com o servidor quando o usuário está autenticado
        if (isAuthenticated) {
            (async () => {
                try {
                    await syncLocalFavoritesToServer(csrfToken);
                } catch (e) {
                    console.error('Erro ao sincronizar favoritos:', e);
                }
            })();
        }

        // --- Comentários: envio e renderização dinâmica ---
        const commentForm = document.getElementById('comment-form');
        const commentText = document.getElementById('comment-text');
        const commentCancel = document.getElementById('comment-cancel');
        const productIdForComments = <%- JSON.stringify(product._id || '') %>

        if (commentCancel) {
            commentCancel.addEventListener('click', (e) => {
                e.preventDefault();
                if (commentText) commentText.value = '';
            });
        }

        if (commentForm && commentList) {
            commentForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const text = commentText.value.trim();
                if (!text) return window.NotificationSystem?.show('Escreva algo antes de enviar.', 'error');

                try {
                    const res = await fetch(`/products/${productIdForComments}/comment`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'x-csrf-token': csrfToken
                        },
                        body: JSON.stringify({ text, _csrf: csrfToken })
                    });

                    const result = await res.json();
                    if (!result) throw new Error('Resposta inválida');
                    showProductNotification(result.message || 'Comentário enviado.', result.success !== false);

                    if (result.success) {
                        // Remove placeholder and example comments if this is the first real comment
                        if (commentPlaceholder) commentPlaceholder.remove();
                        if (sampleCommentsList) {
                            sampleCommentsList.innerHTML = ''; // Clear example comments
                            sampleCommentsList.remove(); // Remove the list itself
                        }
                        // Inserir comentário no DOM
                        const li = document.createElement('li');
                        li.className = 'comment';
                        const avatar = document.createElement('div');
                        avatar.className = 'avatar';
                        avatar.textContent = (result.comment?.author?.nome || (session?.user?.nome) || 'U').charAt(0).toUpperCase();
                        const body = document.createElement('div');
                        body.className = 'body';
                        const meta = document.createElement('div');
                        meta.className = 'meta';
                        meta.innerHTML = `<strong>${(result.comment?.author?.nome) ? result.comment.author.nome : (session?.user?.nome || 'Você')}</strong> • ${new Date().toLocaleString('pt-BR')}`;
                        const textNode = document.createElement('div');
                        textNode.className = 'text';
                        textNode.textContent = result.comment?.texto || result.comment?.text || text;
                        body.appendChild(meta);
                        body.appendChild(textNode); // Append textNode to body

                        // If commentList was empty, ensure it's visible and remove any placeholder text
                        if (commentList.children.length === 0 && commentPlaceholder) {
                            commentPlaceholder.remove();
                        }
                        li.appendChild(avatar);
                        li.appendChild(body);
                        commentList.insertBefore(li, commentList.firstChild);

                        // Atualiza contador
                        const countEl = document.querySelector('.comments-count');
                        if (countEl) {
                            const current = Number(countEl.textContent.match(/\d+/)?.[0] || 0);
                            countEl.textContent = `${current + 1} comentários`;
                        }

                        commentText.value = '';
                    }
                } catch (err) {
                    console.error('Erro ao enviar comentário:', err);
                    showProductNotification('Não foi possível enviar o comentário.', false);
                }
            });
        }

        // --- Lista de produtos relacionados (vinda do servidor) ---
        const listProductEl = document.getElementById('related-products-container'); // Target the new container
        async function renderRelatedProducts() {
            if (!listProductEl) return;
            try {
                const resp = await fetch('/products');
                const data = await resp.json();
                const products = data?.data || data || [];

                // Filtra por categoria do produto atual (se disponível)
                const currentCategory = <%- JSON.stringify(product.categoria || null) %>
                const currentId = <%- JSON.stringify(product._id) %>

                let related = products.filter(p => String(p._id) !== String(currentId));
                if (currentCategory) {
                    if (Array.isArray(currentCategory)) {
                        related = related.filter(p => (p.categoria || []).some(cat => currentCategory.includes(cat)));
                    } else {
                        related = related.filter(p => (p.categoria && (Array.isArray(p.categoria) ? p.categoria.includes(currentCategory) : p.categoria === currentCategory)));
                    }
                }

                // Pegar no máximo 4 itens
                related = related.slice(0, 4);

                if (related.length === 0) {
                    listProductEl.innerHTML = '<div style="color:#666; padding: 1rem;">Nenhum produto relacionado encontrado.</div>';
                    return;
                }

                // Monta os cartões
                const ul = document.createElement('div');
                ul.className = 'related-grid';
                related.forEach(p => {
                    const imgUrl = p.imagens && p.imagens.length ? `/products/images/${p.imagens[0]}` : '/assets/img/fallback.jpg';
                    const card = document.createElement('a');
                    card.href = `/products/${p._id}`;
                    card.className = 'related-card';
                    card.innerHTML = `
                        <div class="related-thumb"><img src="${imgUrl}" alt="${p.nome}" loading="lazy"></div>
                        <div class="related-info">
                            <div class="related-name">${p.nome}</div>
                            <div class="related-price">${p.preco != null ? Number(p.preco).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) : 'Preço sob consulta'}</div>
                        </div>
                    `;
                    ul.appendChild(card);
                });

                listProductEl.innerHTML = '';
                listProductEl.appendChild(ul);
            } catch (err) {
                console.error('Erro ao buscar produtos relacionados:', err);
            }
        } // Removed dynamic style injection

        renderRelatedProducts();
    });
</script>